<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="min-h-screen">
  <!-- Hero Section -->
  <div class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-discord-blurple/20 via-transparent to-purple-900/20"></div>
    <div class="max-w-7xl mx-auto px-4 py-24 relative">
      <div class="text-center fade-in">
        <div class="w-24 h-24 bg-gradient-to-br from-discord-blurple to-purple-600 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-2xl shadow-discord-blurple/30">
          <i class="fas fa-gavel text-4xl text-white"></i>
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
          <span class="bg-gradient-to-r from-white via-discord-blurple to-purple-400 bg-clip-text text-transparent">Appeal Bot</span>
          <span class="text-discord-blurple"> Advanced</span>
        </h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          A powerful, feature-rich appeal management system for your Discord server. Handle security, raider, game, and custom appeals with an intuitive dashboard.
        </p>
        <div class="flex justify-center gap-4">
          <% if (user) { %>
            <a href="/dashboard" class="btn-discord text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-xl">
              <i class="fas fa-th-large mr-2"></i>Open Dashboard
            </a>
          <% } else { %>
            <a href="/auth/login" class="btn-discord text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-xl">
              <i class="fab fa-discord mr-2"></i>Login with Discord
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Features -->
  <div class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-16 text-white">Powerful Features</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="glass-card rounded-2xl p-6 glow-border fade-in">
        <div class="w-12 h-12 bg-red-500/20 rounded-xl flex items-center justify-center mb-4">
          <i class="fas fa-shield-alt text-red-400 text-xl"></i>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Security Appeals</h3>
        <p class="text-gray-400 text-sm">Handle security-related bans with dedicated forms and review workflows.</p>
      </div>
      <div class="glass-card rounded-2xl p-6 glow-border fade-in">
        <div class="w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center mb-4">
          <i class="fas fa-users-slash text-orange-400 text-xl"></i>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Raider Appeals</h3>
        <p class="text-gray-400 text-sm">Process raider appeals with evidence requirements and automated checks.</p>
      </div>
      <div class="glass-card rounded-2xl p-6 glow-border fade-in">
        <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center mb-4">
          <i class="fas fa-gamepad text-blue-400 text-xl"></i>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Game Appeals</h3>
        <p class="text-gray-400 text-sm">Game ban appeals with customizable questions and staff review tools.</p>
      </div>
      <div class="glass-card rounded-2xl p-6 glow-border fade-in">
        <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center mb-4">
          <i class="fas fa-sliders-h text-purple-400 text-xl"></i>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">Full Dashboard</h3>
        <p class="text-gray-400 text-sm">Configure every setting from a beautiful web dashboard - no code needed.</p>
      </div>
    </div>
  </div>

  <!-- More Features -->
  <div class="max-w-7xl mx-auto px-4 pb-20">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="glass-card rounded-2xl p-6">
        <i class="fas fa-chart-bar text-discord-blurple text-2xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white mb-2">Statistics & Analytics</h3>
        <p class="text-gray-400 text-sm">Track appeal trends, approval rates, and staff performance with real-time stats.</p>
      </div>
      <div class="glass-card rounded-2xl p-6">
        <i class="fas fa-robot text-discord-green text-2xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white mb-2">Auto Responses</h3>
        <p class="text-gray-400 text-sm">Set up automated messages for different appeal statuses and types.</p>
      </div>
      <div class="glass-card rounded-2xl p-6">
        <i class="fas fa-ban text-discord-red text-2xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white mb-2">Blacklist System</h3>
        <p class="text-gray-400 text-sm">Block repeat offenders from submitting appeals with the blacklist feature.</p>
      </div>
      <div class="glass-card rounded-2xl p-6">
        <i class="fas fa-bell text-discord-yellow text-2xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white mb-2">DM Notifications</h3>
        <p class="text-gray-400 text-sm">Users get DM updates on their appeal status changes automatically.</p>
      </div>
      <div class="glass-card rounded-2xl p-6">
        <i class="fas fa-lock text-discord-fuchsia text-2xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white mb-2">Role-Based Access</h3>
        <p class="text-gray-400 text-sm">Configure staff, admin, and manager roles for different permission levels.</p>
      </div>
      <div class="glass-card rounded-2xl p-6">
        <i class="fas fa-palette text-green-400 text-2xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white mb-2">Customizable Embeds</h3>
        <p class="text-gray-400 text-sm">Design your appeal panels with custom colors, images, and descriptions.</p>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
