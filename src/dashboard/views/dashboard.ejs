<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="min-h-screen">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-10 fade-in">
      <h1 class="text-3xl font-bold text-white mb-2">Select a Server</h1>
      <p class="text-gray-400">Choose a server to manage its appeal settings.</p>
    </div>

    <% if (guilds.length === 0) { %>
      <div class="glass-card rounded-2xl p-12 text-center">
        <div class="w-16 h-16 bg-discord-blurple/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-server text-discord-blurple text-2xl"></i>
        </div>
        <h2 class="text-xl font-semibold text-white mb-3">No Servers Found</h2>
        <p class="text-gray-400 mb-6">The bot needs to be in a server where you have Manage Server permissions.</p>
        <a href="https://discord.com/api/oauth2/authorize?client_id=<%= process.env.DISCORD_CLIENT_ID %>&permissions=8&scope=bot%20applications.commands"
           target="_blank" class="btn-discord text-white px-6 py-3 rounded-xl font-medium inline-block">
          <i class="fas fa-plus mr-2"></i>Add Bot to Server
        </a>
      </div>
    <% } else { %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% for (const guild of guilds) { %>
          <a href="/dashboard/<%= guild.id %>" class="glass-card rounded-2xl p-6 glow-border block hover:scale-[1.02] transition-all duration-200 fade-in">
            <div class="flex items-center space-x-4 mb-4">
              <% if (guild.icon) { %>
                <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=64"
                     alt="<%= guild.name %>" class="w-14 h-14 rounded-xl shadow-lg">
              <% } else { %>
                <div class="w-14 h-14 bg-gradient-to-br from-discord-blurple to-purple-600 rounded-xl flex items-center justify-center shadow-lg">
                  <span class="text-xl font-bold text-white"><%= guild.name.charAt(0) %></span>
                </div>
              <% } %>
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-semibold text-white truncate"><%= guild.name %></h3>
                <p class="text-sm text-gray-400">ID: <%= guild.id %></p>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-discord-green flex items-center">
                <span class="w-2 h-2 bg-discord-green rounded-full mr-2 pulse-dot"></span>Bot Active
              </span>
              <span class="text-discord-blurple text-sm font-medium">
                Manage <i class="fas fa-arrow-right ml-1"></i>
              </span>
            </div>
          </a>
        <% } %>
      </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
