<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">
    <div class="mb-8 fade-in">
      <h1 class="text-3xl font-bold text-white mb-2">Appeals</h1>
      <p class="text-gray-400">View and manage all appeals submitted to your server.</p>
    </div>

    <!-- Filters -->
    <div class="glass-card rounded-2xl p-4 mb-6 fade-in">
      <form method="GET" class="flex flex-wrap gap-4 items-end">
        <div>
          <label class="block text-xs text-gray-400 mb-1">Status</label>
          <select name="status" class="input-discord rounded-lg px-3 py-2 text-white text-sm outline-none">
            <option value="">All Statuses</option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="under_review" <%= filters.status === 'under_review' ? 'selected' : '' %>>Under Review</option>
            <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
            <option value="denied" <%= filters.status === 'denied' ? 'selected' : '' %>>Denied</option>
            <option value="escalated" <%= filters.status === 'escalated' ? 'selected' : '' %>>Escalated</option>
            <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Type</label>
          <select name="type" class="input-discord rounded-lg px-3 py-2 text-white text-sm outline-none">
            <option value="">All Types</option>
            <% for (const t of appealTypes) { %>
              <option value="<%= t.type_key %>" <%= filters.type === t.type_key ? 'selected' : '' %>><%= t.label %></option>
            <% } %>
          </select>
        </div>
        <button type="submit" class="btn-discord text-white px-4 py-2 rounded-lg text-sm">
          <i class="fas fa-filter mr-1"></i>Filter
        </button>
        <a href="/dashboard/<%= guild.id %>/appeals" class="text-gray-400 hover:text-white transition text-sm px-3 py-2">Clear</a>
      </form>
    </div>

    <!-- Appeals Table -->
    <div class="glass-card rounded-2xl overflow-hidden fade-in">
      <% if (appeals.length === 0) { %>
        <div class="p-12 text-center">
          <i class="fas fa-clipboard-list text-4xl text-gray-600 mb-4"></i>
          <p class="text-gray-400">No appeals found.</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-700/30">
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">ID</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">User</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Type</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Status</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Priority</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Claimed By</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Date</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700/20">
              <% for (const appeal of appeals) { %>
                <%
                  const statusColors = {
                    pending: 'bg-yellow-500/20 text-yellow-400',
                    under_review: 'bg-blue-500/20 text-blue-400',
                    approved: 'bg-green-500/20 text-green-400',
                    denied: 'bg-red-500/20 text-red-400',
                    escalated: 'bg-purple-500/20 text-purple-400',
                    closed: 'bg-gray-500/20 text-gray-400',
                  };
                  const priorityColors = {
                    low: 'text-gray-400',
                    normal: 'text-blue-400',
                    high: 'text-orange-400',
                    urgent: 'text-red-400',
                  };
                %>
                <tr class="hover:bg-discord-blurple/5 transition">
                  <td class="px-6 py-4 text-sm font-mono text-discord-blurple">#<%= appeal.id %></td>
                  <td class="px-6 py-4 text-sm text-white"><%= appeal.user_tag || appeal.user_id %></td>
                  <td class="px-6 py-4 text-sm text-gray-300 capitalize"><%= appeal.appeal_type %></td>
                  <td class="px-6 py-4">
                    <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= statusColors[appeal.status] || 'bg-gray-500/20 text-gray-400' %>">
                      <%= appeal.status.replace(/_/g, ' ') %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm <%= priorityColors[appeal.priority] || 'text-gray-400' %> capitalize"><%= appeal.priority %></td>
                  <td class="px-6 py-4 text-sm text-gray-400"><%= appeal.claimed_by_tag || '-' %></td>
                  <td class="px-6 py-4 text-sm text-gray-400"><%= new Date(appeal.created_at).toLocaleDateString() %></td>
                  <td class="px-6 py-4">
                    <a href="/dashboard/<%= guild.id %>/appeals/<%= appeal.id %>" class="text-discord-blurple hover:text-white transition text-sm">
                      <i class="fas fa-eye mr-1"></i>View
                    </a>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="px-6 py-4 border-t border-gray-700/30 text-sm text-gray-400">
          Showing <%= appeals.length %> appeal(s)
        </div>
      <% } %>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
