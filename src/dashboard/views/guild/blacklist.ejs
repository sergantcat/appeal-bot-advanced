<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">
    <div class="flex justify-between items-center mb-8 fade-in">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Blacklist</h1>
        <p class="text-gray-400">Users blacklisted from submitting appeals.</p>
      </div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="btn-discord text-white px-5 py-3 rounded-xl font-medium">
        <i class="fas fa-plus mr-2"></i>Add User
      </button>
    </div>

    <script>
      if (new URLSearchParams(window.location.search).get('saved')) {
        document.addEventListener('DOMContentLoaded', () => {
          const toast = document.createElement('div');
          toast.className = 'fixed top-20 right-4 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-2xl z-50 fade-in flex items-center';
          toast.innerHTML = '<i class="fas fa-check-circle mr-2"></i>User blacklisted!';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 3000);
        });
      }
    </script>

    <div class="glass-card rounded-2xl overflow-hidden fade-in">
      <% if (blacklist.length === 0) { %>
        <div class="p-12 text-center">
          <i class="fas fa-ban text-4xl text-gray-600 mb-4"></i>
          <p class="text-gray-400">No blacklisted users.</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-700/30">
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">User ID</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Reason</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Added By</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Date</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700/20">
              <% for (const entry of blacklist) { %>
                <tr class="hover:bg-discord-blurple/5 transition">
                  <td class="px-6 py-4 text-sm font-mono text-white"><%= entry.user_id %></td>
                  <td class="px-6 py-4 text-sm text-gray-300"><%= entry.reason || 'No reason' %></td>
                  <td class="px-6 py-4 text-sm text-gray-400"><%= entry.added_by_tag || entry.added_by %></td>
                  <td class="px-6 py-4 text-sm text-gray-400"><%= new Date(entry.created_at).toLocaleDateString() %></td>
                  <td class="px-6 py-4">
                    <form action="/api/<%= guild.id %>/blacklist/<%= entry.user_id %>/delete" method="POST" onsubmit="return confirm('Remove this user from the blacklist?')">
                      <button type="submit" class="text-red-400 hover:text-red-300 transition text-sm">
                        <i class="fas fa-trash mr-1"></i>Remove
                      </button>
                    </form>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Add User Modal -->
    <div id="addModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
      <div class="glass-card rounded-2xl w-full max-w-md">
        <div class="p-6 border-b border-gray-700/30 flex justify-between items-center">
          <h2 class="text-xl font-semibold text-white">Blacklist User</h2>
          <button onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-white transition">
            <i class="fas fa-times text-xl"></i>
          </button>
        </div>
        <form action="/api/<%= guild.id %>/blacklist" method="POST" class="p-6 space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">User ID</label>
            <input type="text" name="user_id" class="input-discord w-full rounded-xl px-4 py-3 text-white outline-none" required placeholder="Enter Discord user ID...">
            <p class="text-xs text-gray-500 mt-1">Right-click user in Discord > Copy User ID</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Reason</label>
            <textarea name="reason" rows="3" class="input-discord w-full rounded-xl px-4 py-3 text-white outline-none resize-none" placeholder="Reason for blacklisting..."></textarea>
          </div>
          <button type="submit" class="w-full btn-discord text-white py-3 rounded-xl font-medium">
            <i class="fas fa-ban mr-2"></i>Add to Blacklist
          </button>
        </form>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
