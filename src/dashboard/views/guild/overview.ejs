<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">
    <div class="mb-8 fade-in">
      <h1 class="text-3xl font-bold text-white mb-2">Dashboard Overview</h1>
      <p class="text-gray-400">Quick overview of your appeal system.</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-8">
      <div class="stat-card rounded-xl p-5 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-xs uppercase tracking-wide">Total</span>
          <i class="fas fa-clipboard-list text-discord-blurple"></i>
        </div>
        <p class="text-2xl font-bold text-white"><%= stats.total %></p>
      </div>
      <div class="stat-card rounded-xl p-5 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-xs uppercase tracking-wide">Pending</span>
          <i class="fas fa-clock text-yellow-400"></i>
        </div>
        <p class="text-2xl font-bold text-yellow-400"><%= stats.pending %></p>
      </div>
      <div class="stat-card rounded-xl p-5 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-xs uppercase tracking-wide">Reviewing</span>
          <i class="fas fa-search text-blue-400"></i>
        </div>
        <p class="text-2xl font-bold text-blue-400"><%= stats.underReview %></p>
      </div>
      <div class="stat-card rounded-xl p-5 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-xs uppercase tracking-wide">Approved</span>
          <i class="fas fa-check-circle text-green-400"></i>
        </div>
        <p class="text-2xl font-bold text-green-400"><%= stats.approved %></p>
      </div>
      <div class="stat-card rounded-xl p-5 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-xs uppercase tracking-wide">Denied</span>
          <i class="fas fa-times-circle text-red-400"></i>
        </div>
        <p class="text-2xl font-bold text-red-400"><%= stats.denied %></p>
      </div>
      <div class="stat-card rounded-xl p-5 fade-in">
        <div class="flex items-center justify-between mb-2">
          <span class="text-gray-400 text-xs uppercase tracking-wide">Escalated</span>
          <i class="fas fa-exclamation-triangle text-purple-400"></i>
        </div>
        <p class="text-2xl font-bold text-purple-400"><%= stats.escalated %></p>
      </div>
    </div>

    <!-- Appeal Types Overview -->
    <div class="grid lg:grid-cols-2 gap-6 mb-8">
      <div class="glass-card rounded-2xl p-6 fade-in">
        <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-layer-group mr-2 text-discord-blurple"></i>Appeal Types</h2>
        <% if (appealTypes.length === 0) { %>
          <div class="text-center py-8">
            <p class="text-gray-400 mb-4">No appeal types configured yet.</p>
            <a href="/dashboard/<%= guild.id %>/appeal-types" class="btn-discord text-white px-4 py-2 rounded-lg text-sm">
              <i class="fas fa-plus mr-2"></i>Set Up Appeal Types
            </a>
          </div>
        <% } else { %>
          <div class="space-y-3">
            <% for (const type of appealTypes) { %>
              <div class="flex items-center justify-between p-3 bg-discord-darkest/50 rounded-xl">
                <div class="flex items-center space-x-3">
                  <span class="text-lg"><%= type.emoji || '📋' %></span>
                  <div>
                    <p class="text-white font-medium"><%= type.label %></p>
                    <p class="text-xs text-gray-400"><%= type.type_key %></p>
                  </div>
                </div>
                <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= type.enabled ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>">
                  <%= type.enabled ? 'Active' : 'Disabled' %>
                </span>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

      <div class="glass-card rounded-2xl p-6 fade-in">
        <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-chart-pie mr-2 text-discord-blurple"></i>Appeals by Type</h2>
        <% if (stats.byType && stats.byType.length > 0) { %>
          <div class="space-y-4">
            <% for (const typeStat of stats.byType) { %>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm text-gray-300 capitalize"><%= typeStat.appeal_type %></span>
                  <span class="text-sm text-gray-400"><%= typeStat.count %> total</span>
                </div>
                <div class="w-full bg-discord-darkest rounded-full h-2.5">
                  <% const pct = stats.total > 0 ? (typeStat.count / stats.total * 100) : 0; %>
                  <div class="bg-gradient-to-r from-discord-blurple to-purple-500 h-2.5 rounded-full" style="width: <%= pct %>%"></div>
                </div>
                <div class="flex justify-between text-xs text-gray-500 mt-1">
                  <span class="text-green-400"><%= typeStat.approved %> approved</span>
                  <span class="text-red-400"><%= typeStat.denied %> denied</span>
                </div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="text-center py-8">
            <p class="text-gray-400">No appeal data yet.</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="glass-card rounded-2xl p-6 fade-in">
      <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-bolt mr-2 text-yellow-400"></i>Quick Actions</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/dashboard/<%= guild.id %>/settings" class="bg-discord-darkest/50 hover:bg-discord-blurple/10 border border-discord-blurple/10 hover:border-discord-blurple/30 rounded-xl p-4 text-center transition">
          <i class="fas fa-cog text-2xl text-gray-400 mb-2"></i>
          <p class="text-sm text-gray-300">Configure Settings</p>
        </a>
        <a href="/dashboard/<%= guild.id %>/appeal-types" class="bg-discord-darkest/50 hover:bg-discord-blurple/10 border border-discord-blurple/10 hover:border-discord-blurple/30 rounded-xl p-4 text-center transition">
          <i class="fas fa-layer-group text-2xl text-gray-400 mb-2"></i>
          <p class="text-sm text-gray-300">Manage Types</p>
        </a>
        <a href="/dashboard/<%= guild.id %>/appeals" class="bg-discord-darkest/50 hover:bg-discord-blurple/10 border border-discord-blurple/10 hover:border-discord-blurple/30 rounded-xl p-4 text-center transition">
          <i class="fas fa-clipboard-list text-2xl text-gray-400 mb-2"></i>
          <p class="text-sm text-gray-300">View Appeals</p>
        </a>
        <a href="/dashboard/<%= guild.id %>/blacklist" class="bg-discord-darkest/50 hover:bg-discord-blurple/10 border border-discord-blurple/10 hover:border-discord-blurple/30 rounded-xl p-4 text-center transition">
          <i class="fas fa-ban text-2xl text-gray-400 mb-2"></i>
          <p class="text-sm text-gray-300">Manage Blacklist</p>
        </a>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
