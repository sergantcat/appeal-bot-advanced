<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">
    <div class="flex justify-between items-center mb-8 fade-in">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Response Templates</h1>
        <p class="text-gray-400">Pre-made response templates for staff to use when reviewing appeals.</p>
      </div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="btn-discord text-white px-5 py-3 rounded-xl font-medium">
        <i class="fas fa-plus mr-2"></i>New Template
      </button>
    </div>

    <script>
      if (new URLSearchParams(window.location.search).get('saved')) {
        document.addEventListener('DOMContentLoaded', () => {
          const toast = document.createElement('div');
          toast.className = 'fixed top-20 right-4 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-2xl z-50 fade-in flex items-center';
          toast.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Template saved!';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 3000);
        });
      }
    </script>

    <% if (templates.length === 0) { %>
      <div class="glass-card rounded-2xl p-12 text-center fade-in">
        <i class="fas fa-file-alt text-4xl text-gray-600 mb-4"></i>
        <p class="text-gray-400 mb-2">No templates yet.</p>
        <p class="text-gray-500 text-sm">Create templates for common appeal responses to save time.</p>
      </div>
    <% } else { %>
      <div class="grid md:grid-cols-2 gap-6">
        <% for (const tmpl of templates) { %>
          <div class="glass-card rounded-2xl p-6 fade-in">
            <div class="flex items-center justify-between mb-3">
              <div>
                <h3 class="text-white font-semibold"><%= tmpl.name %></h3>
                <span class="text-xs text-discord-blurple capitalize"><%= tmpl.category %></span>
              </div>
              <form action="/api/<%= guild.id %>/templates/<%= tmpl.id %>/delete" method="POST" onsubmit="return confirm('Delete this template?')">
                <button type="submit" class="text-red-400 hover:text-red-300 transition text-sm">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
            </div>
            <div class="bg-discord-darkest/50 rounded-lg p-3">
              <p class="text-gray-300 text-sm whitespace-pre-wrap"><%= tmpl.content %></p>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- Add Template Modal -->
    <div id="addModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
      <div class="glass-card rounded-2xl w-full max-w-lg">
        <div class="p-6 border-b border-gray-700/30 flex justify-between items-center">
          <h2 class="text-xl font-semibold text-white">New Template</h2>
          <button onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-white transition">
            <i class="fas fa-times text-xl"></i>
          </button>
        </div>
        <form action="/api/<%= guild.id %>/templates" method="POST" class="p-6 space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Name</label>
              <input type="text" name="name" class="input-discord w-full rounded-xl px-4 py-3 text-white outline-none" required placeholder="e.g. Standard Approval">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Category</label>
              <select name="category" class="input-discord w-full rounded-xl px-4 py-3 text-white outline-none">
                <option value="general">General</option>
                <option value="approval">Approval</option>
                <option value="denial">Denial</option>
                <option value="escalation">Escalation</option>
                <option value="note">Staff Note</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Content</label>
            <textarea name="content" rows="6" class="input-discord w-full rounded-xl px-4 py-3 text-white outline-none resize-none" required placeholder="Template content..."></textarea>
          </div>
          <button type="submit" class="w-full btn-discord text-white py-3 rounded-xl font-medium">
            <i class="fas fa-plus mr-2"></i>Create Template
          </button>
        </form>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
