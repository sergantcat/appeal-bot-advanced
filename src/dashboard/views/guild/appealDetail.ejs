<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">
    <%
      const statusColors = {
        pending: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
        under_review: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
        approved: 'bg-green-500/20 text-green-400 border-green-500/30',
        denied: 'bg-red-500/20 text-red-400 border-red-500/30',
        escalated: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
        closed: 'bg-gray-500/20 text-gray-400 border-gray-500/30',
      };
      let responses = {};
      try { responses = JSON.parse(appeal.responses || '{}'); } catch(e) {}
    %>

    <div class="mb-8 fade-in">
      <div class="flex items-center space-x-4 mb-2">
        <a href="/dashboard/<%= guild.id %>/appeals" class="text-gray-400 hover:text-white transition">
          <i class="fas fa-arrow-left"></i>
        </a>
        <h1 class="text-3xl font-bold text-white">Appeal #<%= appeal.id %></h1>
        <span class="px-3 py-1 rounded-full text-sm font-medium border <%= statusColors[appeal.status] || '' %>">
          <%= appeal.status.replace(/_/g, ' ').toUpperCase() %>
        </span>
      </div>
    </div>

    <script>
      if (new URLSearchParams(window.location.search).get('updated')) {
        document.addEventListener('DOMContentLoaded', () => {
          const toast = document.createElement('div');
          toast.className = 'fixed top-20 right-4 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-2xl z-50 fade-in flex items-center';
          toast.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Appeal updated!';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 3000);
        });
      }
    </script>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Appeal Info -->
      <div class="lg:col-span-2 space-y-6">
        <div class="glass-card rounded-2xl p-6 fade-in">
          <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-info-circle mr-2 text-discord-blurple"></i>Appeal Details</h2>
          <div class="grid md:grid-cols-2 gap-4 mb-6">
            <div class="bg-discord-darkest/50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">User</p>
              <p class="text-white font-medium"><%= appeal.user_tag || 'Unknown' %></p>
              <p class="text-xs text-gray-400 font-mono"><%= appeal.user_id %></p>
            </div>
            <div class="bg-discord-darkest/50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Type</p>
              <p class="text-white font-medium capitalize"><%= appeal.appeal_type %></p>
            </div>
            <div class="bg-discord-darkest/50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Priority</p>
              <p class="text-white font-medium capitalize"><%= appeal.priority %></p>
            </div>
            <div class="bg-discord-darkest/50 rounded-xl p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Submitted</p>
              <p class="text-white font-medium"><%= new Date(appeal.created_at).toLocaleString() %></p>
            </div>
            <% if (appeal.claimed_by) { %>
              <div class="bg-discord-darkest/50 rounded-xl p-4">
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Claimed By</p>
                <p class="text-white font-medium"><%= appeal.claimed_by_tag || appeal.claimed_by %></p>
              </div>
            <% } %>
            <% if (appeal.closed_at) { %>
              <div class="bg-discord-darkest/50 rounded-xl p-4">
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Closed At</p>
                <p class="text-white font-medium"><%= new Date(appeal.closed_at).toLocaleString() %></p>
              </div>
            <% } %>
          </div>

          <!-- Responses -->
          <h3 class="text-md font-semibold text-white mb-3">Responses</h3>
          <div class="space-y-3">
            <% for (const [question, answer] of Object.entries(responses)) { %>
              <div class="bg-discord-darkest/50 rounded-xl p-4">
                <p class="text-xs text-discord-blurple font-semibold uppercase tracking-wide mb-2"><%= question %></p>
                <p class="text-gray-300 text-sm whitespace-pre-wrap"><%= answer || 'No response' %></p>
              </div>
            <% } %>
            <% if (Object.keys(responses).length === 0) { %>
              <p class="text-gray-500 text-sm">No responses recorded.</p>
            <% } %>
          </div>
        </div>

        <!-- Staff Notes -->
        <% if (appeal.staff_notes) { %>
          <div class="glass-card rounded-2xl p-6 fade-in">
            <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-sticky-note mr-2 text-yellow-400"></i>Staff Notes</h2>
            <div class="bg-discord-darkest/50 rounded-xl p-4">
              <pre class="text-gray-300 text-sm whitespace-pre-wrap font-sans"><%= appeal.staff_notes %></pre>
            </div>
          </div>
        <% } %>

        <!-- Denial Reason or Resolution -->
        <% if (appeal.denial_reason) { %>
          <div class="glass-card rounded-2xl p-6 border border-red-500/20 fade-in">
            <h2 class="text-lg font-semibold text-red-400 mb-4"><i class="fas fa-times-circle mr-2"></i>Denial Reason</h2>
            <p class="text-gray-300"><%= appeal.denial_reason %></p>
          </div>
        <% } %>
        <% if (appeal.resolution_notes) { %>
          <div class="glass-card rounded-2xl p-6 border border-green-500/20 fade-in">
            <h2 class="text-lg font-semibold text-green-400 mb-4"><i class="fas fa-check-circle mr-2"></i>Resolution Notes</h2>
            <p class="text-gray-300"><%= appeal.resolution_notes %></p>
          </div>
        <% } %>

        <!-- Activity Log -->
        <div class="glass-card rounded-2xl p-6 fade-in">
          <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-history mr-2 text-discord-blurple"></i>Activity Log</h2>
          <% if (logs.length > 0) { %>
            <div class="space-y-3">
              <% for (const log of logs) { %>
                <div class="flex items-start space-x-3 p-3 bg-discord-darkest/30 rounded-lg">
                  <div class="w-8 h-8 rounded-full bg-discord-blurple/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <i class="fas fa-circle-dot text-discord-blurple text-xs"></i>
                  </div>
                  <div class="flex-1">
                    <p class="text-sm text-white">
                      <span class="font-medium"><%= log.actor_tag || 'System' %></span>
                      <span class="text-gray-400"> - <%= log.action.replace(/_/g, ' ') %></span>
                    </p>
                    <% if (log.details) { %>
                      <p class="text-xs text-gray-400 mt-1"><%= log.details %></p>
                    <% } %>
                    <p class="text-xs text-gray-500 mt-1"><%= new Date(log.created_at).toLocaleString() %></p>
                  </div>
                </div>
              <% } %>
            </div>
          <% } else { %>
            <p class="text-gray-500 text-sm">No activity logged.</p>
          <% } %>
        </div>
      </div>

      <!-- Sidebar Actions -->
      <div class="space-y-6">
        <div class="glass-card rounded-2xl p-6 fade-in">
          <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-bolt mr-2 text-yellow-400"></i>Actions</h2>
          <div class="space-y-3">
            <% if (!['approved', 'denied', 'closed'].includes(appeal.status)) { %>
              <form action="/api/<%= guild.id %>/appeals/<%= appeal.id %>/status" method="POST">
                <input type="hidden" name="status" value="approved">
                <div class="mb-2">
                  <textarea name="notes" rows="2" class="input-discord w-full rounded-lg px-3 py-2 text-white outline-none text-sm resize-none" placeholder="Resolution notes (optional)..."></textarea>
                </div>
                <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-2.5 rounded-xl font-medium transition text-sm">
                  <i class="fas fa-check mr-2"></i>Approve
                </button>
              </form>

              <form action="/api/<%= guild.id %>/appeals/<%= appeal.id %>/status" method="POST">
                <input type="hidden" name="status" value="denied">
                <div class="mb-2">
                  <textarea name="notes" rows="2" class="input-discord w-full rounded-lg px-3 py-2 text-white outline-none text-sm resize-none" placeholder="Denial reason..." required></textarea>
                </div>
                <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-xl font-medium transition text-sm">
                  <i class="fas fa-times mr-2"></i>Deny
                </button>
              </form>

              <form action="/api/<%= guild.id %>/appeals/<%= appeal.id %>/status" method="POST">
                <input type="hidden" name="status" value="escalated">
                <input type="hidden" name="notes" value="Escalated from dashboard">
                <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white py-2.5 rounded-xl font-medium transition text-sm">
                  <i class="fas fa-exclamation-triangle mr-2"></i>Escalate
                </button>
              </form>
            <% } %>

            <% if (!['closed'].includes(appeal.status)) { %>
              <form action="/api/<%= guild.id %>/appeals/<%= appeal.id %>/status" method="POST">
                <input type="hidden" name="status" value="closed">
                <input type="hidden" name="notes" value="Closed from dashboard">
                <button type="submit" class="w-full bg-gray-600 hover:bg-gray-700 text-white py-2.5 rounded-xl font-medium transition text-sm">
                  <i class="fas fa-lock mr-2"></i>Close
                </button>
              </form>
            <% } %>

            <% if (['approved', 'denied', 'closed'].includes(appeal.status)) { %>
              <div class="text-center py-4">
                <p class="text-gray-400 text-sm">This appeal has been resolved.</p>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Quick Info -->
        <div class="glass-card rounded-2xl p-6 fade-in">
          <h2 class="text-lg font-semibold text-white mb-4"><i class="fas fa-info mr-2 text-discord-blurple"></i>Quick Info</h2>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-400">Appeal ID</span>
              <span class="text-white font-mono">#<%= appeal.id %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Type</span>
              <span class="text-white capitalize"><%= appeal.appeal_type %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Status</span>
              <span class="capitalize <%= (statusColors[appeal.status] || '').split(' ')[1] %>"><%= appeal.status.replace(/_/g, ' ') %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Priority</span>
              <span class="text-white capitalize"><%= appeal.priority %></span>
            </div>
            <% if (appeal.thread_id) { %>
              <div class="flex justify-between">
                <span class="text-gray-400">Thread</span>
                <span class="text-discord-blurple font-mono text-xs"><%= appeal.thread_id %></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
